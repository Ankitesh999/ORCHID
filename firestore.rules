rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : null;
    }

    match /users/{uid} {
      allow read: if signedIn() && (role() == "admin" || request.auth.uid == uid);
      allow write: if signedIn() && role() == "admin";
    }

    match /incidents/{incidentId} {
      allow read: if signedIn() && (role() == "admin" || role() == "responder");
      allow create, update, delete: if signedIn() && role() == "admin";
    }
  }
}
