rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() ? request.auth.token.role : null;
    }

    function responderPresenceUpdate(uid) {
      return request.auth.uid == uid
        && role() == "responder"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastKnownLocation",
          "updatedAt",
          "availability"
        ]);
    }

    function responderBidWrite(bidId) {
      return signedIn()
        && role() == "responder"
        && request.auth.uid == bidId
        && request.resource.data.keys().hasOnly([
          "responderId",
          "timestamp",
          "score",
          "distance"
        ])
        && request.resource.data.responderId == request.auth.uid
        && request.resource.data.timestamp is string
        && request.resource.data.score is number
        && request.resource.data.distance is number;
    }

    function responderResolveUpdate() {
      return signedIn()
        && role() == "responder"
        && resource.data.assignedResponderId == request.auth.uid
        && resource.data.status in ["assigned", "acknowledged"]
        && request.resource.data.status == "resolved"
        && request.resource.data.resolvedBy == request.auth.uid
        && request.resource.data.resolvedAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "resolvedAt",
          "resolvedBy",
          "resolution",
          "updatedAt"
        ]);
    }

    function responderReportWrite(reportId) {
      return signedIn()
        && role() == "responder"
        && request.auth.uid == reportId
        && request.resource.data.responderId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "responderId",
          "situation",
          "actionsTaken",
          "additionalResourcesNeeded",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.situation is string
        && request.resource.data.actionsTaken is string
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    match /users/{uid} {
      allow read: if signedIn() && (role() == "admin" || request.auth.uid == uid);
      allow create, delete: if signedIn() && role() == "admin";
      allow update: if signedIn() && (role() == "admin" || responderPresenceUpdate(uid));
    }

    match /incidents/{incidentId} {
      allow read: if signedIn() && (role() == "admin" || role() == "responder");
      allow create, delete: if signedIn() && role() == "admin";
      allow update: if signedIn() && (role() == "admin" || responderResolveUpdate());

      match /bids/{bidId} {
        allow read: if signedIn() && (role() == "admin" || role() == "responder");
        allow create, update: if responderBidWrite(bidId);
      }

      match /reports/{reportId} {
        allow read: if signedIn() && (role() == "admin" || request.auth.uid == reportId);
        allow create, update: if responderReportWrite(reportId);
        allow delete: if signedIn() && role() == "admin";
      }
    }

    match /hazards/{hazardId} {
      allow read: if signedIn();
      allow create, delete: if signedIn() && role() == "admin";
    }
  }
}
